{
  "version": 2,
  "functions": {
    "api/stats.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/commands.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/reviews.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/stats",
      "dest": "/api/stats.js"
    },
    {
        "src": "/commands",
        "dest": "/api/commands.js"
    },
    {
      "src": "/reviews(?:/(.*))?",
      "dest": "/api/reviews.js?path=$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
