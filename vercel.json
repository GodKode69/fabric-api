{
  "version": 2,
  "functions": {
    "api/stats.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/stats",
      "dest": "/api/stats.js"
    },
    {
        "src": "/commands",
        "dest": "/api/commands.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}